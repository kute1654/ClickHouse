-- Comparison of every (Decimal-like, numeric) type pair, in both directions, with every
-- comparison operator and every combination of constant and non-constant arguments.
-- Each row pins down one type pair, so a failure points to the exact pair and shape.
-- The values are chosen small enough that no pair overflows during scale conversion;
-- the overflowing cases are covered by 04523_type_pair_matrix_errors and
-- 04520_type_pair_matrix_division_overflow_errors.
--
-- This is part 1 of 2: it covers a Decimal-typed left operand against every numeric and
-- decimal right operand. Part 2 (04518_type_pair_matrix_comparison_integer_left) covers an
-- integer/date-typed left operand against Decimal, the date/time pairs and the same-type
-- controls. The suite was split so that each file's single run stays within the flaky-check
-- runtime budget while the union keeps the whole matrix and the same per-file shape coverage.

{% set int_types = ['UInt8','UInt16','UInt32','UInt64','UInt128','UInt256','Int8','Int16','Int32','Int64','Int128','Int256'] %}
{% set decimal_types = ['Decimal32','Decimal64','Decimal128','Decimal256'] %}
{% set ops = ['=','!=','<','>','<=','>='] %}

{% set one = {
    'UInt8':   "toUInt8(1)",
    'UInt16':  "toUInt16(1)",
    'UInt32':  "toUInt32(1)",
    'UInt64':  "toUInt64(1)",
    'UInt128': "toUInt128(1)",
    'UInt256': "toUInt256(1)",
    'Int8':    "toInt8(1)",
    'Int16':   "toInt16(1)",
    'Int32':   "toInt32(1)",
    'Int64':   "toInt64(1)",
    'Int128':  "toInt128(1)",
    'Int256':  "toInt256(1)",
    'Decimal32':  "toDecimal32('1.00', 2)",
    'Decimal64':  "toDecimal64('1.0000', 4)",
    'Decimal128': "toDecimal128('1', 10)",
    'Decimal256': "toDecimal256('1', 20)"
} %}

{% set other = {
    'UInt8':   "toUInt8(77)",
    'UInt16':  "toUInt16(77)",
    'UInt32':  "toUInt32(77)",
    'UInt64':  "toUInt64(77)",
    'UInt128': "toUInt128(77)",
    'UInt256': "toUInt256(77)",
    'Int8':    "toInt8(-77)",
    'Int16':   "toInt16(-77)",
    'Int32':   "toInt32(-77)",
    'Int64':   "toInt64(-77)",
    'Int128':  "toInt128(-77)",
    'Int256':  "toInt256(-77)",
    'Decimal32':  "toDecimal32('-7.25', 2)",
    'Decimal64':  "toDecimal64('-3.5', 4)",
    'Decimal128': "toDecimal128('-12.75', 10)",
    'Decimal256': "toDecimal256('-42.5', 20)"
} %}
{# The decimal 'other' entries differ per width so that a cross-width Decimal-vs-Decimal pair
   feeds unequal operands into the const-shape unequal slots below; otherwise DecimalComparison's
   constantVector / vectorConstant / both-const branches would only ever see equal decimals and an
   operand-order bug in those branches for mixed decimals would go unnoticed. #}

{% macro cmprow(label, l1, r1, l2, r2) -%}
SELECT '{{ label }}'
{%- for op in ops -%}
, materialize({{ l1 }}) {{ op }} materialize({{ r1 }}), {{ l1 }} {{ op }} materialize({{ r1 }}), materialize({{ l1 }}) {{ op }} {{ r1 }}, identity({{ l1 }}) {{ op }} identity({{ r1 }})
{%- endfor -%}
{%- for op in ops -%}
, materialize({{ l2 }}) {{ op }} materialize({{ r2 }}), materialize({{ l1 }}) {{ op }} materialize({{ r2 }}), materialize({{ l2 }}) {{ op }} materialize({{ r1 }}), {{ l2 }} {{ op }} materialize({{ r2 }}), materialize({{ l2 }}) {{ op }} {{ r2 }}, identity({{ l2 }}) {{ op }} identity({{ r2 }})
{%- endfor -%};
{%- endmacro %}

{% for L in decimal_types %}
{% for R in int_types + decimal_types %}
{{ cmprow(L ~ ' vs ' ~ R, one[L], one[R], other[L], other[R]) }}
{% endfor %}
{% endfor %}
