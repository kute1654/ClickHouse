== inferred schema (array of records, no Map inference) ==
m_int	Array(Tuple(\n    key Int32,\n    value Int32))					
m_swapped	Array(Tuple(\n    value Int64,\n    key String))					
m_nullable_val	Array(Tuple(\n    key Int32,\n    value Nullable(Int64)))					
m_one_name_value	Array(Tuple(\n    value Int32,\n    extra Int32))					
m_one_name_key	Array(Tuple(\n    extra Int32,\n    key Int32))					

== read as Array(Tuple(...)) (already worked) ==
[(1,42)]
[(2,7),(3,8)]
[]

== read as Map(Int32, Int32) (the fix) ==
{1:42}
{2:7,3:8}
{}

== map lookup by key works ==
0
8
0

== value type coercion Map(Int32, Int64) ==
{1:42}
{2:7,3:8}
{}

== fields routed by name: value declared before key, no logicalType, Map(String, Int64) ==
{'a':100}
{'b':200,'c':300}
{}

== nullable value Map(Int32, Nullable(Int64)) ==
{1:10}
{2:NULL,3:30}
{}

== only one canonical name (value, field 0): stays positional, key from field 0 ==
{10:20}
{11:21,12:22}
{}

== only one canonical name (key, field 1): stays positional, key from field 0 ==
{30:40}
{31:41,32:42}
{}

== all three maps together ==
{1:42}	{'a':100}	{1:10}
{2:7,3:8}	{'b':200,'c':300}	{2:NULL,3:30}
{}	{}	{}

