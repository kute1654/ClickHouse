# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# Skill scaffolds (internal docs for Claude Code, not user-facing pages).
# Ignore everything under .mintlify/ EXCEPT each skill's SKILL.md definition.
# The deploy pipeline honors .mintignore, so ignoring all of .mintlify/ hid the
# SKILL.md files from skill discovery and they never published to
# /.well-known/agent-skills. Keeping SKILL.md visible lets the deploy publish the
# agent skills, while scaffolding (rules/, reference/, metadata.json, AGENTS.md,
# etc.) stays ignored so it never becomes a doc page.
.mintlify/*
!.mintlify/skills/
.mintlify/skills/*/*
!.mintlify/skills/*/SKILL.md

# Lint tooling (Node-only markdownlint/Vale rules). Mintlify injects every
# .js file in the repo as a browser custom script; these throw
# ("require is not defined", "Identifier 'filterTokens' has already been
# declared" on re-injection) and can abort injection of the real scripts.
_site/styles/

# Legacy Docusaurus content at the docs root. Anchor with a leading slash so
# these match only the top-level dirs -- an unanchored `changelogs/` also matched
# `resources/changelogs/` (gitignore any-depth semantics) and hid the real,
# published changelog pages, which docs.json still references.
/_description_templates/
/changelogs/
/en/
